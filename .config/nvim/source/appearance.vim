" UI
set termguicolors
colorscheme dracula
let g:airline_theme='minimalist'
set cmdheight=2
set noshowmode
set number relativenumber
set nu rnu
set wrap
set confirm
set ruler
set scl=no
set shortmess+=c
set pumheight=5
syntax on
autocmd vimenter * hi Normal guibg=NONE ctermbg=NONE

" Brackets
set showmatch
